# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/synthdata

# JWT
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Credential encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-to-a-fernet-key-in-production

# App
APP_ENV=development
APP_NAME=SynthData API
ALLOWED_ORIGINS=http://localhost:3000

# Outputs storage (local for dev, swap to S3 path in prod)
OUTPUTS_DIR=outputs
